                "description": "Target distributions",
                "options": [
                    {
                        "description": "Yocto Project Reference Distro",
                        "name": "distro/poky"
                    },
                    {
                        "description": "Poky alternative with systemd as init manager",
                        "name": "distro/poky-altcfg"
                    },
                    {
                        "description": "Poky alternative optimized for size",
                        "name": "distro/poky-tiny"
                    }
                ]
            },
            "machine": {
                "description": "Target machines",
                "options": [
                    {
                        "description": "x86-64 system on QEMU",
                        "name": "machine/qemux86-64"
                    },
                    {
                        "description": "ARMv8 system on QEMU",
                        "name": "machine/qemuarm64"
                    },
                    {
                        "description": "RISC-V system on QEMU",
                        "name": "machine/qemuriscv64"
                    },
                    {
                        "description": "Arm64 SystemReady IR/ES platforms",
