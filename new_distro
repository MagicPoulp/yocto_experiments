# Install all required dependencies
sudo apt-get update
sudo apt-get install -y \
  gawk wget git diffstat unzip texinfo gcc build-essential \
  chrpath socat cpio python3 python3-pip python3-pexpect \
  xz-utils debianutils iputils-ping python3-git \
  python3-jinja2 libegl1 libsdl1.2-dev \
  pylint xterm python3-subunit mesa-common-dev zstd \
  lz4 file locales libacl1

# Clone Poky at the Scarthgap LTS branch
git clone -b scarthgap https://git.yoctoproject.org/poky
cd poky

# From inside the poky directory
source oe-init-build-env ../build    # sets up the build environment

# Go back and create your layer
bitbake-layers create-layer ../meta-mydistro

This creates:

meta-mydistro/
├── conf/
│   └── layer.conf        ← auto-generated
├── recipes-example/
└── README


mkdir -p meta-mydistro/conf/distro
mkdir -p meta-mydistro/recipes-core/images
mkdir -p meta-mydistro/recipes-kernel/linux

# create them (see the full guide)

#add the checksums
wget https://cdn.kernel.org/pub/linux/kernel/v7.x/sha256sums.asc
Then grep for your specific file:
grep linux-7 sha256sums.asc

# add layers

cd build
bitbake-layers add-layer ../meta-mydistro

# build

# Still inside the build directory
source ../poky/oe-init-build-env .

# Build your image
bitbake mydistro-image

# comment out debconf in the kerbnel .bb file
# compile a debconf, then add it in the kernel.bb
# the command can take 20min

# in build
bitbake linux-kernel7 -c menuconfig
# from build/..
mkdir -p meta-mydistro/recipes-kernel/linux/files
mkdir ../meta-mydistro/recipes-kernel/linux/files/
cp ./tmp-glibc/work/qemux86_64-oe-linux/linux-kernel7/7.0.3/build/.config \
    ../meta-mydistro/recipes-kernel/linux/files/defconfig

